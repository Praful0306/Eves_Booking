{
  "name": "eves",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@eves/api",
    "build": "npm run build --workspace=@eves/shared && npm run build --workspace=@eves/api",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=./prisma/schema.prisma --force",
    "test": "vitest",
    "lint": "eslint apps packages --ext .ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prisma": "^5.15.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
